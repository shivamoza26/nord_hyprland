@import "shared/colors.rasi"
@import "shared/fonts.rasi"

configuration {
    font: "Caskaydia Mono Nerd 13";
    show-icons: false;
    display-drun: "";
}

* {
    background-color:   @background;
    text-color:         @foreground;
    border-color:       @background-alt;
}

window {
    background-color:   @background;
    border:             1px;
    border-color:       @background-alt;
    border-radius:      12px;
    padding:            12px;
    width:              250px;
}

mainbox {
    background-color:   transparent;
    children:           [ inputbar, listview ];
    spacing:            8px;
}

inputbar {
    background-color:   @background-alt;
    border-radius:      8px;
    padding:            8px 12px;
    children:           [ prompt, textbox-prompt-colon, entry ];
}

prompt {
    font:               "Caskaydia Mono Nerd 13";
    background-color:   transparent;
    text-color:         @selected;
    padding:            0 4px 0 0;
}

textbox-prompt-colon {
    background-color:   transparent;
    text-color:         @background-alt;
    expand:             false;
    str:                " ";
}

entry {
    background-color:   transparent;
    text-color:         @foreground;
    placeholder-color:  @background-alt;
    placeholder:        "Search settings...";
}

listview {
    background-color:   transparent;
    lines:              8;
    spacing:            4px;
    scrollbar:          false;
}

element {
    background-color:   transparent;
    border-radius:      6px;
    padding:            8px 12px;
    text-color:         @foreground;
    spacing:            8px;
}

element-icon {
    background-color:   transparent;
    text-color:         @selected;
    size:               24px;
}

element-text {
    background-color:   transparent;
    text-color:         inherit;
    vertical-align:     0.5;
}

element selected {
    background-color:   @selected;
    text-color:         @background;
}

element selected element-icon {
    text-color:         @background;
}

element alternate {
    background-color:   transparent;
}
